{
	"name": "obsidian-mermaid-zoom",
	"version": "1.1.2",
	"description": "Pan, zoom, and navigate Mermaid diagrams in Obsidian with a GitHub-style control panel.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev":     "node esbuild.config.mjs",
		"build":   "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint":    "eslint src/"
	},
	"keywords": ["obsidian", "mermaid", "zoom", "pan", "diagram"],
	"author": "HuuDoe",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@eslint/js": "^9.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"globals": "^15.0.0",
		"obsidian": "latest",
		"tslib": "^2.6.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"jiti": "^2.0.0"
	}
}
